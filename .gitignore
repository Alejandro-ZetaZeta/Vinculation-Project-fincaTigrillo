# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
app/node_modules
android-shell/node_modules
app/.pnp
app/.pnp.*
app/.yarn/*
app/.yarn/patches
app/.yarn/plugins
app/.yarn/releases
app/.yarn/versions

# testing
app/coverage

# next.js
app/.next/
app/out/

# production
app/build

# misc
.DS_Store
*.pem

# Android signing — keystore files must never be committed
*.jks
*.keystore
keystore.properties
local.properties
.gradle/
build/
android/app/build/
android/.gradle/
android/local.properties
capture.png

# iOS shell — generated native workspace, never commit partial Xcode state
ios-shell/node_modules
ios-shell/ios/
ios-shell/build/
ios-shell/dist/
ios-shell/*.xcuserstate
ios-shell/*.xcuserdatad/
ios-shell/xcuserdata/
ios-shell/.swiftpm/
ios-shell/Package.resolved
# Xcode metadata that leaks into the local native workspace
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap
*.dSYM
*.dSYM.zip
# CocoaPods artifacts (regenerated via `pod install`)
**/Pods/
**/*.podspec.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
app/.env*
.env*

# vercel
app/.vercel

# typescript
app/next-env.d.ts

